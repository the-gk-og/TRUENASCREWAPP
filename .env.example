# .env.example - Configuration Examples
# Copy this file to .env and customize for your deployment

# ============================================================================
# ENVIRONMENT SELECTION
# ============================================================================
# Options: development (default), beta, production, testing
#
# DEVELOPMENT: Local development with file-based SQLite. No setup required.
# BETA:        Beta/UAT testing with separate file-based SQLite. Good for staging.
# PRODUCTION:  Production with PostgreSQL. Requires DATABASE_URL setup.
# TESTING:     Unit tests with in-memory SQLite. Don't set this manually.

# 1. LOCAL DEVELOPMENT (Instant Setup - No Database Server Needed)
# ============================================================================
# FLASK_ENV=development
# - Uses sqlite:///production_crew.db (main data)
# - Uses sqlite:///security.db (security database)
# - No setup required, perfect for rapid development

# 2. BETA TESTING (Staging/UAT - Still File-based SQLite)
# ============================================================================
# FLASK_ENV=beta
# - Uses sqlite:///beta_crew.db (main data)
# - Uses sqlite:///beta_security.db (security database - separate from dev!)
# - Perfect for testing on staging servers without database infrastructure
# - Can override URLs if needed:
#   DATABASE_URL=postgresql://user:pass@host/beta_db
#   SECURITY_DATABASE_URL=postgresql://user:pass@host/beta_security_db

# 3. PRODUCTION (Multi-Instance Ready - PostgreSQL Required)
# ============================================================================
# FLASK_ENV=production
# DATABASE_URL=postgresql://user:password@db.example.com:5432/showwise_prod
# SECURITY_DATABASE_URL=postgresql://user:password@secure-db.example.com:5432/showwise_security
# - Production databases REQUIRED (cannot use SQLite)
# - Security DB can be shared across multiple ShowWise instances
# - HTTPS/Cloudflare cookies enabled automatically


# ============================================================================
# GENERAL SETTINGS (All Environments)
# ============================================================================
SECRET_KEY=your-very-secret-key-change-this-in-production

# Session duration: 1w (1 week), 1d (1 day), 1h (1 hour), 30m (30 minutes)
SESSION_DURATION=1w

# ============================================================================
# MAIL CONFIGURATION
# ============================================================================
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@showwise.local

# ============================================================================
# ORGANIZATION / BRANDING
# ============================================================================
ORGANIZATION_SLUG=your-org-slug
MAIN_SERVER_URL=https://showwise.example.com
SIGNUP_BASE_URL=https://showwise.example.com

# ============================================================================
# DISCORD INTEGRATION (Optional)
# ============================================================================
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_WEBHOOK_URL=https://discordapp.com/api/webhooks/...
DISCORD_GUILD_ID=your-guild-id
DISCORD_BOT_SECRET=your-discord-bot-secret

# ============================================================================
# GOOGLE OAUTH (Optional)
# ============================================================================
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://showwise.example.com/auth/google/callback

# ============================================================================
# MULTI-INSTANCE DEPLOYMENT (Optional)
# ============================================================================
# When deploying multiple ShowWise instances with a shared security database,
# name each instance so that security alerts track which instance detected threats:
#
# Instance 1 (NYC Office):
# SHOWWISE_INSTANCE_NAME=nyc-office
#
# Instance 2 (LA Office):
# SHOWWISE_INSTANCE_NAME=la-office
#
# Instance 3 (London Office):
# SHOWWISE_INSTANCE_NAME=london-office
#
# Then point all instances to the same SECURITY_DATABASE_URL
# Security logs will include app_instance field showing which office detected the threat
SHOWWISE_INSTANCE_NAME=default

# ============================================================================
# CLOUDFLARE TUNNEL (If Using Tunnel Instead of Direct Domain)
# ============================================================================
# ShowWise automatically detects and uses CF-Connecting-IP header
# from Cloudflare tunnels - no configuration needed!
# Works with both tunnel and direct domain deployments
